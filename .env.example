# ============================================================
# TAS AutoBD — Environment Configuration Template
# Copy this file to .env and fill in your API keys
# ============================================================

# ----------------------------
# LLM Provider Selection
# Options: "anthropic" (default, recommended) | "openai"
# ----------------------------
LLM_PROVIDER=anthropic

# ----------------------------
# Anthropic API Key (Required if LLM_PROVIDER=anthropic)
# Get one at: https://console.anthropic.com/
# ----------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ----------------------------
# OpenAI API Key (Required if LLM_PROVIDER=openai)
# Get one at: https://platform.openai.com/api-keys
# ----------------------------
OPENAI_API_KEY=your_openai_api_key_here

# ----------------------------
# Required: Tavily Search API Key
# Get one at: https://app.tavily.com
# Free tier: 1,000 searches/month
# ----------------------------
TAVILY_API_KEY=your_tavily_api_key_here

# ----------------------------
# Optional: SendGrid API Key (for automated email sending)
# Get one at: https://sendgrid.com
# Free tier: 100 emails/day
# ----------------------------
SENDGRID_API_KEY=your_sendgrid_api_key_here

# ----------------------------
# Optional: Sender Email Address (must be verified in SendGrid)
# ----------------------------
SENDER_EMAIL=noreply@yourcompany.com

# ----------------------------
# Optional: GitHub Personal Access Token
# Increases GitHub API rate limit from 60 to 5,000 req/hour
# Get one at: https://github.com/settings/tokens
# ----------------------------
GITHUB_TOKEN=your_github_token_here

# ----------------------------
# Model Configuration (optional — defaults shown)
# ----------------------------
# Anthropic model options: claude-sonnet-4-6 (default), claude-opus-4-6, claude-haiku-4-5-20251001
# OpenAI model options:    gpt-4o, gpt-4o-mini
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.3

# HuggingFace embedding model (free, no API key needed)
# BAAI/bge-small-en-v1.5 is fast and high quality (SOTA open-source)
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Working directory for downloaded repos and FAISS index
DATA_DIR=./data
