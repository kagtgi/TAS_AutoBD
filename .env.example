# ============================================================
# TAS AutoBD — Environment Configuration Template
# Copy this file to .env and fill in your API keys
# ============================================================

# ----------------------------
# Required: OpenAI API Key
# Get one at: https://platform.openai.com/api-keys
# ----------------------------
OPENAI_API_KEY=your_openai_api_key_here

# ----------------------------
# Required: Tavily Search API Key
# Get one at: https://app.tavily.com
# ----------------------------
TAVILY_API_KEY=your_tavily_api_key_here

# ----------------------------
# Required: SendGrid API Key (for email sending)
# Get one at: https://sendgrid.com
# ----------------------------
SENDGRID_API_KEY=your_sendgrid_api_key_here

# ----------------------------
# Required: Sender Email Address (must be verified in SendGrid)
# ----------------------------
SENDER_EMAIL=noreply@yourcompany.com

# ----------------------------
# Optional: GitHub Personal Access Token
# Increases GitHub API rate limit from 60 to 5000 req/hour
# Get one at: https://github.com/settings/tokens
# ----------------------------
GITHUB_TOKEN=your_github_token_here

# ----------------------------
# Optional: Model & Path Configuration
# ----------------------------
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
EMBEDDING_MODEL=text-embedding-3-large
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Working directory for downloaded repos and FAISS index
DATA_DIR=./data
